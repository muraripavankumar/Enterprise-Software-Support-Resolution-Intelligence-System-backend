# Runtime / API
APP_ENV=local
ENABLE_AUTH0=true
LOG_FORMAT=text

# CORS
CORS_ALLOW_ORIGINS=http://localhost:5173,http://127.0.0.1:5173
CORS_ALLOW_METHODS=GET,POST,OPTIONS
CORS_ALLOW_HEADERS=Authorization,Content-Type
CORS_ALLOW_CREDENTIALS=true

# Rate limiting
REQUIRE_REDIS_FOR_RATE_LIMITING_NON_LOCAL=true

# Langfuse / Evaluation
LANGFUSE_PUBLIC_KEY=
LANGFUSE_SECRET_KEY=
LANGFUSE_HOST=https://cloud.langfuse.com
ENABLE_LLM_JUDGE=true
LLM_JUDGE_MODEL=gpt-4o-mini

# Jira / mcp-atlassian
ENABLE_JIRA_MCP=false
JIRA_URL=
JIRA_USERNAME=
JIRA_API_TOKEN=
JIRA_PROJECT_KEY=
JIRA_SECURITY_PROJECT_KEY=
JIRA_DEFAULT_ISSUE_TYPE=Task
JIRA_CRITICAL_ISSUE_TYPE=Bug
JIRA_HUMAN_ENGINEERING_ISSUE_TYPE=Task
JIRA_CRITICAL_PRIORITY=Highest
JIRA_HIGH_PRIORITY=High
JIRA_MEDIUM_PRIORITY=Medium
JIRA_DEFAULT_LABEL=eris
JIRA_COMPONENT_NAME=
JIRA_TRIAGE_STATUS=Triage
JIRA_TRIAGE_TRANSITION_ID=
JIRA_DEDUPE_WINDOW_DAYS=7
JIRA_MCP_COMMAND=uvx
JIRA_MCP_ARGS=mcp-atlassian
JIRA_MCP_TIMEOUT_SECONDS=45
AUDIT_LOG_BASE_URL=

# Escalation email / SMTP
ENABLE_ESCALATION_EMAIL_MCP=false
ESCALATION_EMAIL_TO=support-team@example.com,incident-response@example.com
ESCALATION_EMAIL_FROM=eris-alerts@example.com
SMTP_HOST=smtp.example.com
SMTP_PORT=587
SMTP_USERNAME=
SMTP_PASSWORD=
SMTP_USE_TLS=true
SMTP_TIMEOUT_SECONDS=15
